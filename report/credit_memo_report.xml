<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <template id="custom_report_credit_memo">
    <t t-call="web.external_layout">
    <t t-foreach="docs" t-as="o">

    <div class="page" style="font-family: Arial, sans-serif; font-size: 13px; padding: 20px;">
    <main>

      <!-- HEADER (Company header handled by external_layout) -->
      <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:25px;">
        <div></div>
        <!-- CREDIT MEMO TITLE UPPER RIGHT -->
        <div style="text-align:right;">
          <p style="font-size:24px; font-weight:bold; margin:0;">CREDIT MEMO</p>
          <p style="font-size:16px; margin:3px 0 0 0;">CM-<t t-esc="o.name"/></p>
        </div>
      </div>

      <!-- CUSTOMER BLOCK -->
      <div style="display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:20px;">

        <!-- Left: Customer Table -->
        <table style="width:60%; border-collapse:collapse; font-size:13px; border:1px solid #000;">
          <tr style="background:#f7f7f7;">
            <td style="width:20%; font-weight:bold; padding:8px;">To:</td>
            <td style="padding:8px; font-weight:bold;"><t t-esc="o.partner_id.name"/></td>
          </tr>
          <tr>
            <td style="font-weight:bold; padding:8px;">Address:</td>
            <td style="padding:8px;"><t t-esc="o.partner_id.contact_address or ''"/></td>
          </tr>
          <tr>
            <td style="font-weight:bold; padding:8px;">VAT REG TIN:</td>
            <td style="padding:8px;"><t t-esc="o.partner_id.vat or ''"/></td>
          </tr>
        </table>

        <!-- Right: Date -->
        <div style="text-align:right; font-size:13px; margin-top:-15px; padding-left:20px;">
            <strong>DATE:</strong>
            <t t-esc="o.invoice_date.strftime('%m/%d/%Y %H:%M:%S') if o.invoice_date else (o.create_date.strftime('%m/%d/%Y %H:%M:%S') if o.create_date else '')"/>
        </div>

      </div>


      <!-- CLEAN PROFESSIONAL DESCRIPTION & AMOUNTS TABLE -->
      <table style="width:100%; border-collapse:collapse; font-size:13px; border:1px solid #000;">
        <thead>
          <tr style="background:#f2f2f2;">
            <th style="width:70%; padding:8px; text-align:left;">DESCRIPTION</th>
            <th style="width:30%; padding:8px; text-align:right;">AMOUNT</th>
          </tr>
        </thead>

        <tbody>
          <tr>
            <!-- Left Column: Remarks, Reference, Reason -->
            <td style="padding:0;">
              <table style="width:100%; border-collapse:collapse; font-size:13px;">
                <tr>
                  <td style="padding:6px 8px;"><strong>REMARKS:</strong></td>
                  <td style="padding:6px 8px; text-align:right;"><t t-esc="o.state or ''"/></td>
                </tr>
                <tr>
                  <td style="padding:6px 8px;"><strong>REFERENCE:</strong> <t t-esc="o.ref or ''"/></td>
                  <td style="padding:6px 8px; text-align:right;"><t t-esc="o.x_reference_number"/></td>
                </tr>
                <tr>
                  <td style="padding:6px 8px;"><strong>REASON:</strong> </td>
                  <td style="padding:6px 8px; text-align:right;"></td>
                </tr>
              </table>
            </td>

            <!-- Right Column: Subtotal, VAT, Other Charges -->
            <td style="padding:0; vertical-align:top;">
              <table style="width:100%; border-collapse:collapse; font-size:13px;">
                <tr>
                  <td style="padding:6px 8px; font-weight:bold;">Subtotal</td>
                  <td style="padding:6px 8px; text-align:right;"><t t-esc="o.amount_untaxed"/></td>
                </tr>
                <tr>
                  <td style="padding:6px 8px; font-weight:bold;">VAT</td>
                  <td style="padding:6px 8px; text-align:right;"><t t-esc="o.amount_tax"/></td>
                </tr>
                <tr>
                  <td style="padding:6px 8px; font-weight:bold;">Other Charges</td>
                  <td style="padding:6px 8px; text-align:right;">0.00</td>
                </tr>
              </table>
            </td>
          </tr>
        </tbody>

        <tfoot>
          <tr style="background:#f9f9f9;">
            <td style="padding:8px; font-weight:bold;">TOTAL</td>
            <td style="padding:8px; text-align:right; font-weight:bold;">
              <t t-esc="o.amount_total"/>
            </td>
          </tr>
        </tfoot>
      </table>

      <!-- SIGNATORIES -->
      <table style="width:100%; border-collapse:collapse; text-align:center; margin-top:40px; font-size:12px;">
        <tr>
          <td style="border:1px solid black; padding:12px; font-weight:bold;">PREPARED BY:</td>
          <td style="border:1px solid black; padding:12px; font-weight:bold;">CERTIFIED CORRECT BY:</td>
          <td style="border:1px solid black; padding:12px; font-weight:bold;">APPROVED BY:</td>
        </tr>
        <tr style="height:70px;">
          <td style="border:1px solid black;"></td>
          <td style="border:1px solid black;"></td>
          <td style="border:1px solid black;"></td>
        </tr>
      </table>

    </main>
    </div>

    </t>
    </t>
  </template>

  <!-- REPORT ACTION -->
  <record id="action_report_credit_memo_custom" model="ir.actions.report">
    <field name="name">Credit Memo</field>
    <field name="model">account.move</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">itc_internal_dev.custom_report_credit_memo</field>
    <field name="print_report_name">'Credit Memo - %s' % (object.name)</field>
    <field name="binding_model_id" ref="account.model_account_move"/>
    <field name="binding_type">report</field>
  </record>

</odoo>
