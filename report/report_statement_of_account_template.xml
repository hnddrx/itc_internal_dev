<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <!-- ==========================
       QWeb Template: Statement of Account
  =========================== -->
  <template id="custom_report_statement_of_account">
    <t t-call="web.external_layout">
      <t t-foreach="docs" t-as="partner">
        <div class="page" style="font-family: Arial, sans-serif; font-size: 13px; line-height:1.5;">
          <main>
            <!-- HEADER -->
            <table style="width:100%; border-collapse:collapse; margin-bottom:20px;">
              <tr>
                <td style="width:70%; border:1px solid #000; padding:8px;">
                  <strong style="font-size:18px;">STATEMENT OF ACCOUNT</strong><br/>
                  <strong>Customer:</strong> <t t-esc="partner.name"/><br/>
                  <strong>Address:</strong> <t t-esc="partner.contact_address or ''"/><br/>
                  <strong>TIN:</strong> <t t-esc="partner.vat or ''"/>
                </td>
                <td style="width:30%; border:1px solid #000; padding:8px; text-align:right;">
                  <strong>Date:</strong><br/>
                  <strong>Generated By:</strong> <t t-esc="user.name"/>
                </td>
              </tr>
            </table>

            <!-- TABLE -->
            <table style="width:100%; border-collapse:collapse; font-size:12px;">
              <thead style="background-color:#f0f0f0;">
                <tr>
                  <th style="border:1px solid #000; padding:5px;">Invoice No.</th>
                  <th style="border:1px solid #000; padding:5px;">Invoice Date</th>
                  <th style="border:1px solid #000; padding:5px;">Due Date</th>
                  <th style="border:1px solid #000; padding:5px; text-align:right;">Amount Due</th>
                  <th style="border:1px solid #000; padding:5px; text-align:right;">Balance</th>
                </tr>
              </thead>
              <tbody>
                <t t-set="due_invoices" t-value="env['account.move'].search([
                  ('move_type', '=', 'out_invoice'),
                  ('state', '=', 'posted'),
                  ('payment_state', '=', 'not_paid'),
                ])"/>
                
                <t t-if="due_invoices">
                  <tr t-foreach="due_invoices" t-as="inv">
                    <td style="border:1px solid #000; padding:5px;"><t t-esc="inv.name"/></td>
                    <td style="border:1px solid #000; padding:5px;"><t t-esc="inv.invoice_date"/></td>
                    <td style="border:1px solid #000; padding:5px;"><t t-esc="inv.invoice_date_due"/></td>
                    <td style="border:1px solid #000; padding:5px; text-align:right;">
                      <t t-esc="inv.currency_id.symbol"/> <t t-esc="inv.amount_total"/>
                    </td>
                    <td style="border:1px solid #000; padding:5px; text-align:right;">
                      <t t-esc="inv.currency_id.symbol"/> <t t-esc="inv.amount_residual"/>
                    </td>
                  </tr>
                </t>
                <t t-if="not due_invoices">
                  <tr>
                    <td colspan="5" style="border:1px solid #000; padding:8px; text-align:center; color:#888;">
                      No due invoices found.
                    </td>
                  </tr>
                </t>
              </tbody>

              <tfoot>
                <tr>
                  <td colspan="4" style="border:1px solid #000; padding:5px; text-align:right; font-weight:bold;">
                    Total Balance:
                  </td>
                  <td style="border:1px solid #000; padding:5px; text-align:right; font-weight:bold;">
                    <t t-esc="sum(inv.amount_residual for inv in due_invoices)"/>
                  </td>
                </tr>
              </tfoot>
            </table>

            <p style="margin-top:30px; font-size:11px; text-align:center;">
              THIS DOCUMENT IS NOT VALID FOR CLAIM OF INPUT TAX
            </p>
          </main>
        </div>
      </t>
    </t>
  </template>

  <!-- REPORT ACTION -->
  <record id="action_report_statement_of_account" model="ir.actions.report">
    <field name="name">Statement of Account</field>
    <field name="model">res.partner</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">itc_internal_dev.custom_report_statement_of_account</field>
    <field name="print_report_name">'SOA - %s' % (object.name)</field>
  </record>
</odoo>
