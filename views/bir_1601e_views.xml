<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================= -->
    <!-- SEQUENCE                                          -->
    <!-- ================================================= -->

    <record id="seq_bir_1601e" model="ir.sequence">
        <field name="name">BIR 1601-E Annual Return</field>
        <field name="code">bir.1601e</field>
        <field name="prefix">1601E/%(year)s/</field>
        <field name="padding">5</field>
        <field name="number_increment">1</field>
        <field name="number_next">1</field>
        <field name="implementation">no_gap</field>
        <field name="use_date_range">True</field>
        <field name="company_id" eval="False"/>
    </record>


    <!-- ================================================= -->
    <!-- LIST VIEW                                         -->
    <!-- ================================================= -->

    <record id="view_bir_1601e_tree" model="ir.ui.view">
        <field name="name">bir.1601e.list</field>
        <field name="model">bir.1601e</field>
        <field name="arch" type="xml">
            <list
                decoration-info="state == 'draft'"
                decoration-warning="state == 'generated'"
                decoration-success="state in ('confirmed', 'filed')"
                decoration-muted="state == 'cancelled'"
                multi_edit="1">

                <field name="name" string="Reference No."/>
                <field name="display_name" string="Description"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="year"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="total_income_payments"
                       string="Total Income Payments"
                       sum="Total"/>
                <field name="total_tax_required"
                       string="Tax Required"
                       sum="Total"/>
                <field name="tax_previously_remitted"
                       string="Previously Remitted"
                       sum="Total"/>
                <field name="total_tax_still_due"
                       string="Still Due"
                       sum="Total"/>
                <field name="total_amount_payable"
                       string="Amount Payable"
                       sum="Grand Total"/>
                <field name="state"
                       widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'generated'"
                       decoration-primary="state == 'confirmed'"
                       decoration-success="state == 'filed'"
                       decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>


    <!-- ================================================= -->
    <!-- FORM VIEW                                         -->
    <!-- ================================================= -->

    <record id="view_bir_1601e_form" model="ir.ui.view">
        <field name="name">bir.1601e.form</field>
        <field name="model">bir.1601e</field>
        <field name="arch" type="xml">
            <form string="BIR 1601-E Annual Return">

                <header>

                    <button name="action_generate_data"
                            string="Generate Data"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"
                            confirm="This will clear existing lines and re-generate from posted journal entries. Continue?"/>

                    <button name="action_generate_data"
                            string="Re-Generate Data"
                            type="object"
                            class="btn-secondary"
                            invisible="state != 'generated'"
                            confirm="This will clear all existing lines and re-generate from posted journal entries. Continue?"/>

                    <button name="action_confirm"
                            string="Confirm"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'generated'"/>

                    <button name="action_file"
                            string="Mark as Filed"
                            type="object"
                            class="btn-success"
                            invisible="state != 'confirmed'"
                            confirm="Are you sure you want to mark this return as Filed with the BIR? This action cannot be undone."/>

                    <button name="action_reset_to_draft"
                            string="Reset to Draft"
                            type="object"
                            class="btn-secondary"
                            invisible="state not in ('generated', 'confirmed')"/>

                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            class="btn-danger"
                            invisible="state not in ('draft', 'generated')"
                            confirm="Cancel this BIR 1601-E return?"/>

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,generated,confirmed,filed"/>

                </header>

                <sheet>

                    <div class="oe_title">
                        <label for="name" string="Reference"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                        <h2>
                            <field name="display_name" readonly="1"/>
                        </h2>
                        <h4 class="text-muted">
                            Annual Return of Creditable Income Taxes Withheld (Expanded)
                        </h4>
                    </div>

                    <div class="alert alert-success mb-3"
                         invisible="state != 'filed'">
                        <i class="fa fa-check-circle me-2"/>
                        This return has been filed with the BIR on
                        <field name="date_filed" readonly="1" nolabel="1" class="fw-bold d-inline"/>
                        by <field name="filed_by" readonly="1" nolabel="1" class="fw-bold d-inline"/>.
                    </div>

                    <div class="alert alert-warning mb-3"
                         invisible="state != 'cancelled'">
                        <i class="fa fa-ban me-2"/>
                        This return has been cancelled and is no longer active.
                    </div>

                    <group>

                        <group string="Taxpayer Information">
                            <field name="company_id"
                                   readonly="state not in ('draft',)"
                                   options="{'no_create': True}"/>
                            <field name="year"
                                   readonly="state not in ('draft',)"/>
                            <field name="date_from" readonly="1"/>
                            <field name="date_to" readonly="1"/>
                        </group>

                        <group string="Filing Audit">
                            <field name="date_confirmed"
                                   readonly="1"
                                   invisible="not date_confirmed"/>
                            <field name="confirmed_by"
                                   readonly="1"
                                   invisible="not confirmed_by"/>
                            <field name="date_filed"
                                   readonly="1"
                                   invisible="not date_filed"/>
                            <field name="filed_by"
                                   readonly="1"
                                   invisible="not filed_by"/>
                        </group>

                    </group>

                    <separator string="Tax Computation"/>

                    <group>

                        <group string="Income Payments and Tax">
                            <field name="total_income_payments"
                                   readonly="1"
                                   widget="monetary"
                                   options="{'currency_field': 'currency_id'}"/>
                            <field name="total_tax_required"
                                   readonly="1"
                                   widget="monetary"
                                   options="{'currency_field': 'currency_id'}"/>
                            <field name="tax_previously_remitted"
                                   readonly="state in ('confirmed', 'filed', 'cancelled')"
                                   widget="monetary"
                                   options="{'currency_field': 'currency_id'}"/>
                            <field name="total_tax_still_due"
                                   readonly="1"
                                   widget="monetary"
                                   options="{'currency_field': 'currency_id'}"/>
                            <field name="currency_id" invisible="1"/>
                        </group>

                        <group string="Penalties and Total Payable">
                            <field name="surcharge"
                                   readonly="state in ('confirmed', 'filed', 'cancelled')"
                                   widget="monetary"
                                   options="{'currency_field': 'currency_id'}"/>
                            <field name="interest"
                                   readonly="state in ('confirmed', 'filed', 'cancelled')"
                                   widget="monetary"
                                   options="{'currency_field': 'currency_id'}"/>
                            <field name="compromise"
                                   readonly="state in ('confirmed', 'filed', 'cancelled')"
                                   widget="monetary"
                                   options="{'currency_field': 'currency_id'}"/>
                            <field name="total_penalties"
                                   readonly="1"
                                   widget="monetary"
                                   options="{'currency_field': 'currency_id'}"/>
                            <field name="total_amount_payable"
                                   readonly="1"
                                   widget="monetary"
                                   options="{'currency_field': 'currency_id'}"/>
                        </group>

                    </group>

                    <notebook>

                        <page string="Withholding Breakdown" name="breakdown">
                            <field name="line_ids"
                                   readonly="state in ('confirmed', 'filed', 'cancelled')">
                                <list editable="bottom"
                                      decoration-danger="tax_withheld == 0">

                                    <field name="date" optional="show"/>
                                    <field name="partner_id"
                                           string="Payee / Vendor"
                                           optional="show"
                                           options="{'no_create': True}"/>
                                    <field name="move_line_id"
                                           string="Journal Entry"
                                           optional="hide"
                                           readonly="1"/>
                                    <field name="nature_of_payment"/>
                                    <field name="atc" string="ATC"/>
                                    <field name="tax_rate"
                                           string="Rate (%)"
                                           optional="show"/>
                                    <field name="tax_base"
                                           string="Gross Income (Tax Base)"
                                           sum="Total Tax Base"/>
                                    <field name="tax_withheld"
                                           string="Tax Withheld"
                                           readonly="1"
                                           sum="Total Tax Withheld"/>

                                </list>
                            </field>
                        </page>

                        <page string="Notes" name="notes">
                            <field name="notes"
                                   placeholder="Add internal notes, BIR reference numbers, or filing instructions here..."
                                   readonly="state in ('filed', 'cancelled')"/>
                        </page>

                    </notebook>

                </sheet>

                <chatter/>

            </form>
        </field>
    </record>


    <!-- ================================================= -->
    <!-- SEARCH VIEW                                       -->
    <!-- ================================================= -->

    <record id="view_bir_1601e_search" model="ir.ui.view">
        <field name="name">bir.1601e.search</field>
        <field name="model">bir.1601e</field>
        <field name="arch" type="xml">
            <search string="Search BIR 1601-E Returns">

                <field name="name" string="Reference No."/>
                <field name="display_name" string="Description"/>
                <field name="year" string="Year"/>
                <field name="company_id" groups="base.group_multi_company"/>

                <filter string="Draft"
                        name="filter_draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter string="Generated"
                        name="filter_generated"
                        domain="[('state', '=', 'generated')]"/>
                <filter string="Confirmed"
                        name="filter_confirmed"
                        domain="[('state', '=', 'confirmed')]"/>
                <filter string="Filed"
                        name="filter_filed"
                        domain="[('state', '=', 'filed')]"/>
                <filter string="Cancelled"
                        name="filter_cancelled"
                        domain="[('state', '=', 'cancelled')]"/>

                <separator/>

                <filter string="Current Year"
                        name="filter_current_year"
                        domain="[('year', '=', context_today().year)]"/>
                <filter string="Previous Year"
                        name="filter_prev_year"
                        domain="[('year', '=', context_today().year - 1)]"/>

                <group expand="0" string="Group By">
                    <filter string="Company"
                            name="group_company"
                            context="{'group_by': 'company_id'}"
                            groups="base.group_multi_company"/>
                    <filter string="Year"
                            name="group_year"
                            context="{'group_by': 'year'}"/>
                    <filter string="Status"
                            name="group_state"
                            context="{'group_by': 'state'}"/>
                </group>

            </search>
        </field>
    </record>


    <!-- ================================================= -->
    <!-- LINE LIST VIEW                                    -->
    <!-- ================================================= -->

    <record id="view_bir_1601e_line_tree" model="ir.ui.view">
        <field name="name">bir.1601e.line.list</field>
        <field name="model">bir.1601e.line</field>
        <field name="arch" type="xml">
            <list string="Withholding Lines" create="false" delete="false">
                <field name="bir_id" string="Return"/>
                <field name="date"/>
                <field name="partner_id" string="Payee"/>
                <field name="nature_of_payment"/>
                <field name="atc"/>
                <field name="tax_rate" string="Rate (%)"/>
                <field name="tax_base" string="Gross Income" sum="Total"/>
                <field name="tax_withheld" sum="Total"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>


    <!-- ================================================= -->
    <!-- WINDOW ACTION                                     -->
    <!-- ================================================= -->

    <record id="action_bir_1601e" model="ir.actions.act_window">
        <field name="name">BIR 1601-E Returns</field>
        <field name="res_model">bir.1601e</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_bir_1601e_search"/>
        <field name="context">{'search_default_filter_current_year': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No BIR 1601-E Returns Yet
            </p>
            <p>
                Create your first Annual Return of Creditable Income Taxes
                Withheld (Expanded) for the current taxable year.
            </p>
        </field>
    </record>

</odoo>