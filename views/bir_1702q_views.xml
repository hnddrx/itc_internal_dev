<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================= -->
    <!-- SEQUENCE                                          -->
    <!-- ================================================= -->

    <record id="sequence_bir_1702q" model="ir.sequence">
        <field name="name">BIR 1702Q Sequence</field>
        <field name="code">bir.1702q</field>
        <field name="prefix">1702Q/%(year)s/</field>
        <field name="padding">5</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
        <field name="implementation">no_gap</field>
        <field name="use_date_range">True</field>
        <field name="company_id" eval="False"/>
    </record>


    <!-- ================================================= -->
    <!-- LIST VIEW                                         -->
    <!-- ================================================= -->

    <record id="view_bir_1702q_tree" model="ir.ui.view">
        <field name="name">bir.1702q.list</field>
        <field name="model">bir.1702q</field>
        <field name="arch" type="xml">
            <list string="BIR 1702Q Returns"
                  decoration-info="state == 'draft'"
                  decoration-warning="state == 'confirmed'"
                  decoration-success="state == 'filed'"
                  decoration-muted="state == 'cancelled'">

                <field name="name" string="Reference No."/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="year"/>
                <field name="quarter"/>
                <field name="atc_code"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="net_tax_payable"
                       widget="monetary"
                       sum="Total"/>
                <field name="total_amount_payable"
                       widget="monetary"
                       sum="Grand Total"/>
                <field name="state"
                       widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'confirmed'"
                       decoration-success="state == 'filed'"
                       decoration-danger="state == 'cancelled'"/>
                <field name="currency_id" invisible="1"/>
            </list>
        </field>
    </record>


    <!-- ================================================= -->
    <!-- FORM VIEW                                         -->
    <!-- ================================================= -->

    <record id="view_bir_1702q_form" model="ir.ui.view">
        <field name="name">bir.1702q.form</field>
        <field name="model">bir.1702q</field>
        <field name="arch" type="xml">
            <form string="BIR Form 1702Q - Quarterly Income Tax Return">

                <!-- ======================================= -->
                <!-- HEADER                                 -->
                <!-- ======================================= -->

                <header>

                    <button name="action_generate_data"
                            string="Generate Data"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"
                            confirm="This will re-compute all schedules from posted journal entries. Continue?"/>

                    <button name="action_confirm"
                            string="Confirm"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <button name="action_file"
                            string="Mark as Filed"
                            type="object"
                            class="btn-success"
                            invisible="state != 'confirmed'"
                            confirm="Are you sure you want to mark this return as Filed with the BIR? This action cannot be undone."/>

                    <button name="action_draft"
                            string="Reset to Draft"
                            type="object"
                            class="btn-secondary"
                            invisible="state != 'cancelled'"/>

                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            class="btn-danger"
                            invisible="state in ('cancelled', 'filed')"
                            confirm="Cancel this BIR 1702Q return?"/>

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,confirmed,filed"/>

                </header>

                <sheet>

                    <!-- ======================================= -->
                    <!-- TITLE                                  -->
                    <!-- ======================================= -->

                    <div class="oe_title">
                        <label for="name" string="Reference"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                        <h4 class="text-muted">
                            Quarterly Income Tax Return for Corporations and Partnerships
                        </h4>
                    </div>

                    <!-- ======================================= -->
                    <!-- STATUS BANNERS                         -->
                    <!-- ======================================= -->

                    <div class="alert alert-success mb-3"
                         invisible="state != 'filed'">
                        <i class="fa fa-check-circle me-2"/>
                        This return has been filed with the BIR.
                    </div>

                    <div class="alert alert-warning mb-3"
                         invisible="state != 'cancelled'">
                        <i class="fa fa-ban me-2"/>
                        This return has been cancelled and is no longer active.
                    </div>

                    <!-- ======================================= -->
                    <!-- BASIC INFORMATION                      -->
                    <!-- ======================================= -->

                    <group>

                        <group string="Return Information">
                            <field name="company_id"
                                   readonly="state not in ('draft',)"
                                   options="{'no_create': True}"/>
                            <field name="year"
                                   readonly="state not in ('draft',)"/>
                            <field name="quarter"
                                   readonly="state not in ('draft',)"/>
                            <field name="atc_code"
                                   readonly="state not in ('draft',)"/>
                            <field name="fiscal_year"/>
                            <field name="year_ended" readonly="1"/>
                            <field name="is_amended"/>
                        </group>

                        <group string="Company Details">
                            <field name="tin" readonly="1"/>
                            <field name="rdo_code"
                                   readonly="state not in ('draft',)"/>
                            <field name="registered_name" readonly="1"/>
                            <field name="zip_code" readonly="1"/>
                            <field name="contact_number" readonly="1"/>
                            <field name="email" readonly="1"/>
                        </group>

                    </group>

                    <group>

                        <group string="Tax Configuration">
                            <field name="deduction_method"
                                   readonly="state not in ('draft',)"/>
                            <field name="has_tax_relief"/>
                            <field name="tax_relief_specify"
                                   invisible="not has_tax_relief"
                                   readonly="state not in ('draft',)"/>
                        </group>

                        <group string="Filing Period">
                            <field name="date_from" readonly="1"/>
                            <field name="date_to" readonly="1"/>
                        </group>

                    </group>

                    <!-- ======================================= -->
                    <!-- SCHEDULES                              -->
                    <!-- ======================================= -->

                    <notebook>

                        <!-- Schedule 2 first — most commonly used -->
                        <page string="Schedule 2 - Regular/Normal Rate" name="schedule2">
                            <group>
                                <group string="Income">
                                    <field name="s2_sales"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s2_cost"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s2_gross_income"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s2_other_income"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s2_total_gross"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                </group>
                                <group string="Tax Computation">
                                    <field name="s2_deductions"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s2_taxable_income"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s2_previous_quarters"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s2_total_taxable"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s2_tax_rate"
                                           readonly="state not in ('draft',)"/>
                                    <field name="s2_normal_tax"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s2_mcit"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s2_tax_due"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="currency_id" invisible="1"/>
                                </group>
                            </group>
                        </page>

                        <page string="Schedule 3 - MCIT" name="schedule3">
                            <group>
                                <group string="Gross Income by Quarter">
                                    <field name="s3_gross_q1"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s3_gross_q2"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s3_gross_q3"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s3_total_gross"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                </group>
                                <group string="MCIT Computation">
                                    <field name="s3_mcit_rate" readonly="1"/>
                                    <field name="s3_mcit"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                </group>
                            </group>
                        </page>

                        <page string="Schedule 4 - Tax Credits" name="schedule4">
                            <group>
                                <group string="Tax Credits / Payments">
                                    <field name="s4_prior_year_excess"
                                           readonly="state in ('filed', 'cancelled')"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s4_previous_quarters_payment"
                                           readonly="state in ('filed', 'cancelled')"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s4_previous_mcit"
                                           readonly="state in ('filed', 'cancelled')"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s4_previous_creditable"
                                           readonly="state in ('filed', 'cancelled')"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s4_current_creditable"
                                           readonly="state in ('filed', 'cancelled')"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s4_amended_tax_paid"
                                           readonly="state in ('filed', 'cancelled')"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s4_other_credits"
                                           readonly="state in ('filed', 'cancelled')"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s4_total_credits"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                </group>
                            </group>
                        </page>

                        <page string="Schedule 1 - Exempt / Special Rate" name="schedule1">
                            <group>
                                <group string="Exempt Income">
                                    <field name="s1_exempt_sales"
                                           readonly="state in ('filed', 'cancelled')"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s1_exempt_cost"
                                           readonly="state in ('filed', 'cancelled')"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s1_exempt_gross_income"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s1_exempt_other_income"
                                           readonly="state in ('filed', 'cancelled')"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s1_exempt_total_gross"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s1_exempt_deductions"
                                           readonly="state in ('filed', 'cancelled')"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s1_exempt_taxable_income"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s1_exempt_previous_quarters"
                                           readonly="state in ('filed', 'cancelled')"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s1_exempt_total_taxable"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s1_exempt_tax_rate"
                                           readonly="state in ('filed', 'cancelled')"/>
                                    <field name="s1_exempt_tax_due"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s1_exempt_share_agencies"
                                           readonly="state in ('filed', 'cancelled')"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s1_exempt_net_tax"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                </group>
                                <group string="Special Rate Income">
                                    <field name="s1_special_sales"
                                           readonly="state in ('filed', 'cancelled')"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s1_special_cost"
                                           readonly="state in ('filed', 'cancelled')"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s1_special_gross_income"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s1_special_other_income"
                                           readonly="state in ('filed', 'cancelled')"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s1_special_total_gross"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s1_special_deductions"
                                           readonly="state in ('filed', 'cancelled')"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s1_special_taxable_income"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s1_special_previous_quarters"
                                           readonly="state in ('filed', 'cancelled')"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s1_special_total_taxable"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s1_special_tax_rate"
                                           readonly="state in ('filed', 'cancelled')"/>
                                    <field name="s1_special_tax_due"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s1_special_share_agencies"
                                           readonly="state in ('filed', 'cancelled')"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="s1_special_net_tax"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                </group>
                            </group>
                        </page>

                        <page string="Tax Payable" name="tax_payable">
                            <group>
                                <group string="Tax Computation">
                                    <field name="tax_due_normal"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="unexpired_excess_mcit"
                                           readonly="state in ('filed', 'cancelled')"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="balance_tax_normal"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="tax_due_special"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="aggregate_tax_due"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="total_tax_credits"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="net_tax_payable"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                </group>
                                <group string="Penalties">
                                    <field name="surcharge"
                                           readonly="state in ('filed', 'cancelled')"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="interest"
                                           readonly="state in ('filed', 'cancelled')"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="compromise"
                                           readonly="state in ('filed', 'cancelled')"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="total_penalties"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="total_amount_payable"
                                           readonly="1"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                </group>
                            </group>
                        </page>

                        <page string="Payment Details" name="payment">
                            <group>
                                <group string="Payment Information">
                                    <field name="payment_method"
                                           readonly="state in ('filed', 'cancelled')"/>
                                    <field name="payment_bank"
                                           readonly="state in ('filed', 'cancelled')"/>
                                    <field name="payment_number"
                                           readonly="state in ('filed', 'cancelled')"/>
                                    <field name="payment_date"
                                           readonly="state in ('filed', 'cancelled')"/>
                                    <field name="payment_amount"
                                           readonly="state in ('filed', 'cancelled')"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="attachment_count"
                                           readonly="state in ('filed', 'cancelled')"/>
                                </group>
                            </group>
                        </page>

                    </notebook>

                </sheet>

                <chatter/>

            </form>
        </field>
    </record>


    <!-- ================================================= -->
    <!-- SEARCH VIEW                                       -->
    <!-- ================================================= -->

    <record id="view_bir_1702q_search" model="ir.ui.view">
        <field name="name">bir.1702q.search</field>
        <field name="model">bir.1702q</field>
        <field name="arch" type="xml">
            <search string="Search BIR 1702Q Returns">

                <field name="name" string="Reference No."/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="year" string="Year"/>
                <field name="quarter"/>

                <filter string="Draft"
                        name="filter_draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmed"
                        name="filter_confirmed"
                        domain="[('state', '=', 'confirmed')]"/>
                <filter string="Filed"
                        name="filter_filed"
                        domain="[('state', '=', 'filed')]"/>
                <filter string="Cancelled"
                        name="filter_cancelled"
                        domain="[('state', '=', 'cancelled')]"/>

                <separator/>

                <filter string="Current Year"
                        name="filter_current_year"
                        domain="[('year', '=', context_today().year)]"/>
                <filter string="Q1"
                        name="filter_q1"
                        domain="[('quarter', '=', '1')]"/>
                <filter string="Q2"
                        name="filter_q2"
                        domain="[('quarter', '=', '2')]"/>
                <filter string="Q3"
                        name="filter_q3"
                        domain="[('quarter', '=', '3')]"/>

                <group expand="0" string="Group By">
                    <filter string="Company"
                            name="group_company"
                            context="{'group_by': 'company_id'}"
                            groups="base.group_multi_company"/>
                    <filter string="Year"
                            name="group_year"
                            context="{'group_by': 'year'}"/>
                    <filter string="Quarter"
                            name="group_quarter"
                            context="{'group_by': 'quarter'}"/>
                    <filter string="Status"
                            name="group_state"
                            context="{'group_by': 'state'}"/>
                </group>

            </search>
        </field>
    </record>


    <!-- ================================================= -->
    <!-- WINDOW ACTION                                     -->
    <!-- ================================================= -->

    <record id="action_bir_1702q" model="ir.actions.act_window">
        <field name="name">BIR 1702Q Returns</field>
        <field name="res_model">bir.1702q</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_bir_1702q_search"/>
        <field name="context">{'search_default_filter_current_year': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No BIR 1702Q Returns Yet
            </p>
            <p>
                Create your first Quarterly Income Tax Return for Corporations
                and Partnerships. The system will auto-populate data from your
                posted accounting records.
            </p>
        </field>
    </record>

</odoo>