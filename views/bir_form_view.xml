<odoo>
    <record id="view_bir_model_kanban" model="ir.ui.view">
        <field name="name">bir.model.kanban</field>
        <field name="model">bir.model</field>
        <field name="arch" type="xml">
            <kanban create="false">

                <field name="name"/>
                <field name="description"/>
                <field name="image_url"/>
                <field name="action_id"/>

                <templates>
                    <t t-name="kanban-box">
                        <div class="o_kanban_record o_kanban_dashboard_box">

                            <div class="o_kanban_details">

                                <h3>
                                    <t t-esc="record.name.value"/>
                                </h3>

                                <!-- Dynamic Action -->
                                <button type="object"
                                        name="open_action"
                                        class="btn btn-primary mt-2"
                                        >
                                    Open
                                </button>

                            </div>

                        </div>
                    </t>
                </templates>

            </kanban>
        </field>
    </record>


    <record id="bir_demo_0619e" model="bir.model">
        <field name="name">BIR 0619E</field>
        <field name="category">monthly</field>
        <field name="description">Monthly Remittance of Creditable Withholding Tax</field>
        <field name="action_id" ref="action_bir_0619e"/>
    </record>

    <record id="bir_demo_2550m" model="bir.model">
        <field name="name">BIR 2550M</field>
        <field name="category">monthly</field>
        <field name="description">Monthly Remittance of Creditable Withholding Tax</field>
        <!-- <field name="action_id" ref="action_bir_2550m"/> -->
    </record>

    <record id="bir_demo_1601eq" model="bir.model">
