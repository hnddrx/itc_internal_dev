    <record id="view_cash_advance_liquidation_list" model="ir.ui.view">
        <field name="name">cash.advance.liquidation.line.list</field>
        <field name="model">cash.advance.liquidation.line</field>
        <field name="arch" type="xml">
            <list>
                <field name="cash_advance_id"/>
                <field name="date"/>
                <field name="description"/>
                <field name="reference"/>
                <field name="amount"/>
            </list>
        </field>
    </record>

    <record id="view_cash_advance_liquidation_form" model="ir.ui.view">
        <field name="name">cash.advance.liquidation.line.form</field>
        <field name="model">cash.advance.liquidation.line</field>
        <field name="arch" type="xml">
            <form string="Liquidation Line">
                <sheet>
                    <group>
                        <field name="cash_advance_id"/>
                        <field name="date"/>
                        <field name="description"/>
                        <field name="reference"/>
                        <field name="amount"/>
                        <field name="attachment"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

  
    <record id="action_cash_advance_kanban" model="ir.actions.act_window">
        <field name="name">Cash Advances</field>
        <field name="res_model">cash.advance</field>
        <field name="view_mode">kanban,list,form</field>
        <!-- <field name="search_view_id" ref="view_cash_advance_search"/> -->
    </record>

    <record id="action_cash_advance_liquidation_list" model="ir.actions.act_window">
        <field name="name">Liquidation Lines</field>
        <field name="res_model">cash.advance.liquidation.line</field>
        <field name="view_mode">list,form</field>
    </record>

 
    <record id="action_cash_advance_reports" model="ir.actions.act_window">
        <field name="name">Cash Advance Reports</field>
        <field name="res_model">cash.advance</field>
        <field name="view_mode">pivot,graph,list</field>
    </record>

    <menuitem id="menu_cash_advance_root" name="Cash Advance"/>
    <menuitem id="menu_cash_advance_management" name="Cash Advances" parent="menu_cash_advance_root" action="action_cash_advance_kanban"/>
    <menuitem id="menu_cash_advance_liquidation" name="Liquidation Lines" parent="menu_cash_advance_root" action="action_cash_advance_liquidation_list"/>
    <menuitem id="menu_cash_advance_reports" name="Reports" parent="menu_cash_advance_root" action="action_cash_advance_reports"/>

</odoo>