<odoo>
  
  
    
    <record id="view_cash_advance_kanban" model="ir.ui.view">
        <field name="name">cash.advance.kanban</field>
        <field name="model">cash.advance</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="amount_requested"/>
                <field name="balance"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <strong><field name="name"/></strong><br/>
                                <field name="employee_id"/><br/>
                                Requested: <field name="amount_requested"/><br/>
                                Balance: <field name="balance"/>
                            </div>
                            <div class="oe_kanban_footer">
                                <field name="status"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

 
    <record id="view_cash_advance_list" model="ir.ui.view">
        <field name="name">cash.advance.list</field>
        <field name="model">cash.advance</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="request_date"/>
                <field name="amount_requested"/>
                <field name="amount_released"/>
                <field name="balance"/>
                <field name="status" widget="badge"/>
            </list>
        </field>
    </record>

   
    <record id="view_cash_advance_form" model="ir.ui.view">
        <field name="name">cash.advance.form</field>
        <field name="model">cash.advance</field>
        <field name="arch" type="xml">
            <form string="Cash Advance">
                <header>
                    <button string="Submit" type="object" name="action_submit" invisible="status != 'draft'"/>
                    <button string="Manager Approve" type="object" name="action_manager_approve" invisible="status != 'for_approval'"/>
                    <button string="Finance Approve" type="object" name="action_finance_approve" invisible="status != 'finance_approval'"/>
                    <button string="Release" type="object" name="action_release" invisible="status != 'approved'"/>
                    <button string="Submit Liquidation" type="object" name="action_submit_liquidation" invisible="status != 'released'"/>
                    <button string="Liquidate" type="object" name="action_liquidate" invisible="status != 'for_liquidation'"/>
                    <button string="Cancel" type="object" name="action_cancel" invisble="status not in ('draft','for_approval','finance_approval','approved','released','for_liquidation')"/>
                    <button string="Reset to Draft" type="object" name="action_draft" invisilbe="statu != 'cancelled'"/>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="employee_id"/>
                        <field name="department_id"/>
                        <field name="request_date"/>
                        <field name="purpose"/>
                    </group>
                    <group>
                        <field name="amount_requested"/>
                        <field name="amount_released" readonly="1"/>
                        <field name="amount_liquidated" readonly="1"/>
                        <field name="balance" readonly="1"/>
                    </group>
                    <group>
                        <field name="advance_account_id"/>
                        <field name="journal_id"/>
                    </group>
                    <notebook>
                        <page string="Liquidation Lines">
                            <field name="liquidation_line_ids">
                                <list editable="bottom">
                                    <field name="date"/>
                                    <field name="description"/>
                                    <field name="reference"/>
                                    <field name="amount"/>
                                </list>
                            </field>
                        </page>
                        
                    </notebook>
                </sheet>
                <chatter />
            </form>
        </field>
    </record>

