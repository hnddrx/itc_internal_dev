<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Expense Type Form -->
    <record id="view_disbursement_expense_type_form" model="ir.ui.view">
        <field name="name">disbursement.expense.type.form</field>
        <field name="model">disbursement.expense.type</field>
        <field name="arch" type="xml">
            <form string="Expense Type">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="account_id"/>
                        </group>
                    </group>
                    <field name="description"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Expense Type list -->
    <record id="view_disbursement_expense_type_list" model="ir.ui.view">
        <field name="name">disbursement.expense.type.list</field>
        <field name="model">disbursement.expense.type</field>
        <field name="arch" type="xml">
            <list string="Expense Types" editable="top">
                <field name="code"/>
                <field name="name"/>
                <field name="account_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="action_disbursement_expense_type" model="ir.actions.act_window">
        <field name="name">Expense Types</field>
        <field name="res_model">disbursement.expense.type</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
