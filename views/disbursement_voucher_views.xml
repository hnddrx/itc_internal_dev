<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════════════════
         FORM VIEW  –  Disbursement Voucher Transaction
         ══════════════════════════════════════════════════════════════════════ -->
    <record id="view_disbursement_voucher_form" model="ir.ui.view">
        <field name="name">disbursement.voucher.form</field>
        <field name="model">disbursement.voucher</field>
        <field name="arch" type="xml">
            <form string="Disbursement Voucher Transaction">

                <!-- ── Workflow Buttons ───────────────────────────────────── -->
                <header>
                    <button name="action_submit_for_approval"
                            string="Submit for Approval"
                            type="object"
                            class="btn-primary"
                            invisible="status != 'draft'"/>
                    <button name="action_payable_entry"
                            string="Payable Voucher Entry"
                            type="object"
                            class="btn-primary"
                            invisible="status != 'for_approval'"/>
                    <button name="action_disbursement_entry"
                            string="Disbursement Voucher Entry"
                            type="object"
                            class="btn-primary"
                            invisible="status != 'payable_entry'"/>
                    <button name="action_release"
                            string="Release"
                            type="object"
                            class="btn-success"
                            invisible="status != 'disbursement_entry'"/>
                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            class="btn-danger"
                            confirm="Are you sure you want to cancel this voucher?"
                            invisible="status in ('released', 'cancelled')"/>
                    <button name="action_reset_to_draft"
                            string="Reset to Draft"
                            type="object"
                            invisible="status not in ('for_approval', 'payable_entry', 'disbursement_entry', 'cancelled')"/>
                    <button name="action_print_voucher"
                            string="Print"
                            type="object"
                            class="btn-secondary"
                            invisible="status == 'draft'"/>
                    <button name="action_view_journal_entry"
                            string="Journal Entry"
                            type="object"
                            class="btn-link"
                            invisible="not account_move_id"/>
                    <!-- Status bar kept in header for workflow navigation only, not shown as a field below -->
                    <field name="status"
                           widget="statusbar"
                           statusbar_visible="draft,for_approval,payable_entry,disbursement_entry,released"/>
                </header>

                <!-- ── Sheet ──────────────────────────────────────────────── -->
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="voucher_number" readonly="1"/>
                        </h1>
                        <h3 class="text-muted">Disbursement Voucher Transaction</h3>
                    </div>

                    <!-- ── Two-Column Main Form ──────────────────────────── -->
                    <group>
                        <!-- LEFT COLUMN -->
                        <group string="Voucher Information">
                            <field name="voucher_number" readonly="1"/>
                            <field name="voucher_date"/>
                            <field name="payment_date"/>
                            <field name="expense_type_id"/>
                            <field name="payee_type" widget="radio"/>
                            <field name="partner_id"
                                   invisible="payee_type != 'supplier'"
                                   options="{'no_create_edit': True}"/>
                            <field name="employee_id"
                                   invisible="payee_type != 'employee'"/>
                            <field name="supplier_tin"/>
                            <field name="particulars"/>
                            <field name="source_type"/>
                            <field name="company_id"/>
                        </group>

                        <!-- RIGHT COLUMN -->
                        <group string="Amount &amp; Currency">
                            <field name="voucher_amount" readonly="1"/>
                            <field name="payment_amount" readonly="1"/>
                            <field name="currency_id"
                                   options="{'no_create_edit': True}"/>
                            <field name="fx_rate"/>
                            <field name="amount_in_php" readonly="1"/>
                            <separator string="Print Options"/>
                            <field name="show_in_print"/>
                        </group>
                    </group>

                    <!-- ── Remarks Area ──────────────────────────────────── -->
                    <group>
                        <group string="Regular Remarks">
                            <field name="remarks"
                                   nolabel="1"
                                   widget="text"/>
                        </group>
                        <group string="Detailed Remarks">
                            <field name="detailed_remarks"
                                   nolabel="1"
                                   widget="text"/>
                        </group>
                    </group>

                    <!-- ── Control Fields ───────────────────────────────── -->
                    <group>
                        <group>
                            <field name="checked_by_id"
                                   options="{'no_create_edit': True}"/>
                            <field name="checked_date"/>
                        </group>
                        <group>
                            <field name="entry_date" readonly="1"/>
                            <field name="prepared_by_id" readonly="1"/>
                        </group>
                    </group>

                    <!-- ── Tab Notebook ──────────────────────────────────── -->
                    <notebook>

                        <!-- TAB 1: Voucher Details -->
                        <page string="Voucher Details" name="voucher_details">
                            <field name="voucher_line_ids" widget="one2many">
                                <list string="Voucher Details" editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="expense_type_id"/>
                                    <field name="purchase_category"/>
                                    <field name="partner_id" optional="show"/>
                                    <field name="employee_id" optional="hide"/>
                                    <field name="description"/>
                                    <field name="account_id"/>
                                    <field name="vat_type"/>
                                    <field name="amount" sum="Total"/>
                                    <field name="vat_amount" optional="hide" sum="Total VAT"/>
                                    <field name="net_amount" optional="hide"/>
                                    <field name="ewt_rate" optional="hide"/>
                                    <field name="ewt_amount" optional="hide"/>
                                    <field name="analytic_account_id" optional="hide"/>
                                    <field name="notes" optional="hide"/>
                                    <field name="currency_id" invisible="1"/>
                                </list>
                                <form string="Voucher Detail Line">
                                    <group>
                                        <group>
                                            <field name="expense_type_id"/>
                                            <field name="purchase_category"/>
                                            <field name="description"/>
                                            <field name="account_id"/>
                                            <field name="analytic_account_id"/>
                                            <field name="cost_center"/>
                                        </group>
                                        <group>
                                            <field name="partner_id"/>
                                            <field name="employee_id"/>
                                            <field name="vat_type"/>
                                            <field name="amount"/>
                                            <field name="vat_amount" readonly="1"/>
                                            <field name="net_amount" readonly="1"/>
                                            <field name="ewt_rate"/>
                                            <field name="ewt_amount" readonly="1"/>
                                        </group>
                                    </group>
                                    <field name="notes"/>
                                </form>
                            </field>
                        </page>

                        <!-- TAB 2: Payment Details -->
                        <page string="Payment Details" name="payment_details">
                            <field name="payment_detail_ids" widget="one2many">
                                <list string="Payment Details" editable="bottom">
                                    <field name="payment_mode"/>
                                    <field name="check_number"
                                           invisible="payment_mode != 'check'"/>
                                    <field name="check_date"
                                           invisible="payment_mode != 'check'"/>
                                    <field name="bank_id"/>
                                    <field name="reference"/>
                                    <field name="payment_date"/>
                                    <field name="amount" sum="Total"/>
                                    <field name="notes" optional="hide"/>
                                    <field name="currency_id" invisible="1"/>
                                </list>
                            </field>
                        </page>

                        <!-- TAB 3: Extra Credit -->
                        <page string="Extra Credit" name="extra_credit">
                            <field name="extra_credit_ids" widget="one2many">
                                <list string="Extra Credit" editable="bottom">
                                    <field name="credit_type"/>
                                    <field name="description"/>
                                    <field name="account_id"/>
                                    <field name="amount" sum="Total"/>
                                    <field name="notes" optional="hide"/>
                                    <field name="currency_id" invisible="1"/>
                                </list>
                            </field>
                        </page>

                    </notebook>
                </sheet>

                <!-- ── Chatter ───────────────────────────────────────────── -->
                <chatter />
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════════
         list / LIST VIEW
         ══════════════════════════════════════════════════════════════════════ -->
    <record id="view_disbursement_voucher_list" model="ir.ui.view">
        <field name="name">disbursement.voucher.list</field>
        <field name="model">disbursement.voucher</field>
        <field name="arch" type="xml">
            <list string="Disbursement Vouchers"
                  decoration-success="status == 'released'"
                  decoration-info="status in ('payable_entry', 'disbursement_entry')"
                  decoration-warning="status == 'for_approval'"
                  decoration-muted="status == 'cancelled'">
                <field name="voucher_number"/>
                <field name="voucher_date"/>
                <field name="expense_type_id"/>
                <field name="partner_id"/>
                <field name="particulars"/>
                <field name="voucher_amount" sum="Total"/>
                <field name="currency_id" optional="hide"/>
                <field name="amount_in_php" sum="Total PHP" optional="show"/>
                <field name="prepared_by_id" optional="hide"/>
                <field name="status"
                       decoration-success="status == 'released'"
                       decoration-info="status in ('payable_entry', 'disbursement_entry')"
                       decoration-warning="status == 'for_approval'"
                       decoration-muted="status == 'cancelled'"
                       widget="badge"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════════
         SEARCH VIEW
         ══════════════════════════════════════════════════════════════════════ -->
    <record id="view_disbursement_voucher_search" model="ir.ui.view">
        <field name="name">disbursement.voucher.search</field>
        <field name="model">disbursement.voucher</field>
        <field name="arch" type="xml">
            <search string="Search Disbursement Vouchers">
                <field name="voucher_number"/>
                <field name="partner_id"/>
                <field name="expense_type_id"/>
                <field name="particulars"/>
                <field name="prepared_by_id"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('status','=','draft')]"/>
                <filter string="For Approval" name="for_approval"
                        domain="[('status','=','for_approval')]"/>
                <filter string="Payable Entry" name="payable_entry"
                        domain="[('status','=','payable_entry')]"/>
                <filter string="Disbursement Entry" name="disbursement_entry"
                        domain="[('status','=','disbursement_entry')]"/>
                <filter string="Released" name="released"
                        domain="[('status','=','released')]"/>
                <filter string="Cancelled" name="cancelled"
                        domain="[('status','=','cancelled')]"/>
                <separator/>
                <filter string="This Month" name="this_month"
                        domain="[('voucher_date','&gt;=', (context_today()).strftime('%Y-%m-01'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_status"
                            context="{'group_by': 'status'}"/>
                    <filter string="Expense Type" name="group_expense_type"
                            context="{'group_by': 'expense_type_id'}"/>
                    <filter string="Voucher Date" name="group_date"
                            context="{'group_by': 'voucher_date:month'}"/>
                    <filter string="Supplier/Payee" name="group_partner"
                            context="{'group_by': 'partner_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════════
         KANBAN VIEW
         ══════════════════════════════════════════════════════════════════════ -->
    <record id="view_disbursement_voucher_kanban" model="ir.ui.view">
        <field name="name">disbursement.voucher.kanban</field>
        <field name="model">disbursement.voucher</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status" class="o_kanban_small_column">
                <field name="voucher_number"/>
                <field name="partner_id"/>
                <field name="voucher_amount"/>
                <field name="currency_id"/>
                <field name="status"/>
                <field name="voucher_date"/>
                <field name="expense_type_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record_has_image_fill">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <strong><field name="voucher_number"/></strong>
                                </div>
                                <div class="o_kanban_record_body">
                                    <div><field name="partner_id"/></div>
                                    <div><field name="expense_type_id"/></div>
                                    <div>
                                        <field name="voucher_amount"
                                               widget="monetary"
                                               options="{'currency_field': 'currency_id'}"/>
                                    </div>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <small class="text-muted">
                                        <field name="voucher_date"/>
                                    </small>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════════
         ACTIONS
         ══════════════════════════════════════════════════════════════════════ -->
    <record id="action_disbursement_voucher" model="ir.actions.act_window">
        <field name="name">Disbursement Vouchers</field>
        <field name="res_model">disbursement.voucher</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_disbursement_voucher_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Disbursement Voucher
            </p>
            <p>
                Use disbursement vouchers to track and manage company payments
                through the full approval workflow.
            </p>
        </field>
    </record>

    <record id="action_disbursement_for_approval" model="ir.actions.act_window">
        <field name="name">For Approval</field>
        <field name="res_model">disbursement.voucher</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('status','=','for_approval')]</field>
    </record>

    <record id="action_disbursement_payable_entry" model="ir.actions.act_window">
        <field name="name">Payable Voucher Entry</field>
        <field name="res_model">disbursement.voucher</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('status','=','payable_entry')]</field>
    </record>

    <record id="action_disbursement_voucher_entry" model="ir.actions.act_window">
        <field name="name">Disbursement Voucher Entry</field>
        <field name="res_model">disbursement.voucher</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('status','=','disbursement_entry')]</field>
    </record>

    <record id="action_disbursement_released" model="ir.actions.act_window">
        <field name="name">Released Vouchers</field>
        <field name="res_model">disbursement.voucher</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('status','=','released')]</field>
    </record>

</odoo>
