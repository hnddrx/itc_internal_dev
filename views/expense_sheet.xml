<odoo>
    <!-- HR Expense sheet -->
  <record id="view_expense_sheet_form_inherit_discount" model="ir.ui.view">
        <field name="name">hr.expense.sheet.form.inherit.discount</field>
        <field name="model">hr.expense.sheet</field>
        <field name="inherit_id" ref="hr_expense.view_hr_expense_sheet_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='expense_line_ids']/list" position="inside">
                <field name="x_discount_percentage"/>
                <field name="x_discount_amount"/>
            </xpath>
        </field>
    </record>
</odoo>
