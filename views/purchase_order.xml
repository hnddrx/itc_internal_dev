<?xml version="1.0" encoding="utf-8"?>
<odoo>
 <record id="view_purchase_form_inherit_custom" model="ir.ui.view">
    <field name="name">purchase.order.form.inherit.custom</field>
    <field name="model">purchase.order</field>
    <field name="inherit_id" ref="purchase.purchase_order_form"/>
    <field name="arch" type="xml">
      <header position="inside">
            <button name="%(report_purchase_order_custom)d"
                    string="Print IPO"
                    type="action"
                    invisible="x_purchase_type != 'import'"
                    class="btn-primary"/>
            <button name="%(report_purchase_order_custom)d"
                    string="Print LPO"
                    type="action"
                    invisible="x_purchase_type != 'local'"
                    class="btn-primary"/>
      </header>
      <xpath expr="//field[@name='partner_id']" position="before">
         <field name="x_purchase_type" />
      </xpath>
      <xpath expr="//field[@name='partner_id']" position="after">
         <field name="x_vendor_tin" invisible="not partner_id"/>
      </xpath>

      <!-- <xpath expr="//field[@name='date_planned']" position="after">
         <field name="x_noted_by" />
         <field name="x_noted_by_date" widget="datetime"/>
         <field name="x_checked_by"/>
         <field name="x_checked_by_date" widget="datetime"/>
      </xpath> -->


      <xpath expr="//notebook" position="inside">
        <page string="Noted By">
          <group>
            <field name="x_noted_by" string="Name" />
            <field name="x_noted_by_date" string="Date" widget="datetime"/>
          </group>
        </page>
        <page string="Checked By">
          <group>
            <field name="x_checked_by" string="Name" />
            <field name="x_checked_by_date" string="Date" widget="datetime"/>
          </group>
        </page>
        <page string="Remarks/Purpose">
          <group>
            <field name="x_remarks" placeholder="Type here..."/>
          </group>
        </page>
      </xpath>

    </field>
 </record>    
</odoo>
